{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "node ./scripts/copy_docs.js && node ./scripts/extract_sdk_versions.js && node ./scripts/generate_llms_txts.js && node ./scripts/generate_sitemap.js",
    "dev": "node ./scripts/copy_docs.js && node ./scripts/extract_sdk_versions.js && node ./scripts/generate_llms_txts.js && next dev",
    "build": "node ./scripts/copy_docs.js && node ./scripts/extract_sdk_versions.js && node ./scripts/generate_llms_txts.js && node ./scripts/generate_sitemap.js && next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs}\"",
    "generate:sitemap": "node ./scripts/generate_sitemap.js",
    "pretest": "node ./scripts/copy_docs.js && node ./scripts/extract_sdk_versions.js",
    "test": "jest && jest --config jest.integration.config.ts --forceExit",
    "test:unit": "jest",
    "test:integration": "jest --config jest.integration.config.ts --forceExit",
    "test:update-snapshot": "jest --updateSnapshot",
    "test:watch": "jest --watch"
  },
